<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.example.viewcontroller.CompraViewController"
    style="-fx-background-color: #0D0D0D;"
    prefWidth="1200" prefHeight="750">

    <!-- ══ TOP BAR ═════════════════════════════════════════ -->
    <top>
        <HBox
            style="-fx-background-color: #111111;
                   -fx-border-color: #1E1E1E;
                   -fx-border-width: 0 0 1 0;"
            alignment="CENTER_LEFT"
            prefHeight="62"
            spacing="12">

            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>

            <Button
                text="← Volver"
                onAction="#volver"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #777;
                       -fx-font-size: 13px;
                       -fx-cursor: hand;
                       -fx-border-color: #2A2A2A; -fx-border-width: 1;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-padding: 7 16;"/>

            <Label
                text="EVENTIC"
                onMouseClicked="#irInicio"
                style="-fx-font-family: 'Georgia';
                       -fx-font-size: 20px;
                       -fx-font-weight: bold;
                       -fx-text-fill: #E8C547;
                       -fx-cursor: hand;
                       -fx-padding: 0 0 0 8;"/>

            <Label
                fx:id="lblNombreEvento"
                text=""
                style="-fx-text-fill: #444;
                       -fx-font-size: 13px;
                       -fx-padding: 0 0 0 8;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label
                fx:id="lblUsuarioTop"
                text=""
                style="-fx-text-fill: #666; -fx-font-size: 12px;"/>

        </HBox>
    </top>

    <!-- ══ CENTRO ═══════════════════════════════════════════ -->
    <center>
        <HBox
            spacing="0"
            style="-fx-background-color: #0D0D0D;">

            <!-- ── Columna izquierda: selección ─────────── -->
            <ScrollPane
                fitToWidth="true"
                HBox.hgrow="ALWAYS"
                style="-fx-background: #0D0D0D;
                       -fx-background-color: #0D0D0D;
                       -fx-border-color: transparent;">

                <VBox
                    spacing="28"
                    style="-fx-background-color: #0D0D0D;">

                    <padding><Insets top="28" right="32" bottom="32" left="32"/></padding>

                    <!-- PASO 1: Zonas -->
                    <VBox spacing="14">
                        <Label
                            text="1. Selecciona tu zona y entradas"
                            style="-fx-font-family: 'Georgia';
                                   -fx-font-size: 18px;
                                   -fx-font-weight: bold;
                                   -fx-text-fill: #EEEEEE;"/>

                        <!-- Las filas de zona se generan dinámicamente -->
                        <VBox
                            fx:id="panelZonas"
                            spacing="10"/>

                    </VBox>

                    <Separator style="-fx-background-color: #1A1A1A;"/>

                    <!-- PASO 2: Servicios adicionales -->
                    <VBox spacing="14">
                        <Label
                            text="2. Servicios adicionales (opcional)"
                            style="-fx-font-family: 'Georgia';
                                   -fx-font-size: 18px;
                                   -fx-font-weight: bold;
                                   -fx-text-fill: #EEEEEE;"/>

                        <Label
                            text="Agrega servicios extra a tu experiencia"
                            style="-fx-text-fill: #555; -fx-font-size: 12px;"/>

                        <!-- VIP -->
                        <HBox
                            style="-fx-background-color: #161616;
                                   -fx-border-color: #222; -fx-border-width: 1;
                                   -fx-border-radius: 6; -fx-background-radius: 6;"
                            alignment="CENTER_LEFT"
                            spacing="12">
                            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                            <CheckBox
                                fx:id="chkVIP"
                                onAction="#actualizarTotal"
                                style="-fx-text-fill: #CCC; -fx-font-size: 13px;"/>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Acceso VIP"
                                       style="-fx-text-fill: #CCC; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label text="Zona exclusiva, acceso anticipado y cortesías"
                                       style="-fx-text-fill: #555; -fx-font-size: 11px;"/>
                            </VBox>
                            <Label text="+ $50.000"
                                   style="-fx-text-fill: #E8C547; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Seguro -->
                        <HBox
                            style="-fx-background-color: #161616;
                                   -fx-border-color: #222; -fx-border-width: 1;
                                   -fx-border-radius: 6; -fx-background-radius: 6;"
                            alignment="CENTER_LEFT"
                            spacing="12">
                            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                            <CheckBox
                                fx:id="chkSeguro"
                                onAction="#actualizarTotal"
                                style="-fx-text-fill: #CCC; -fx-font-size: 13px;"/>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Seguro de cancelación"
                                       style="-fx-text-fill: #CCC; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label text="Reembolso completo si cancelas con 48h de anticipación"
                                       style="-fx-text-fill: #555; -fx-font-size: 11px;"/>
                            </VBox>
                            <Label text="+ $10.000"
                                   style="-fx-text-fill: #E8C547; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Merchandising -->
                        <HBox
                            style="-fx-background-color: #161616;
                                   -fx-border-color: #222; -fx-border-width: 1;
                                   -fx-border-radius: 6; -fx-background-radius: 6;"
                            alignment="CENTER_LEFT"
                            spacing="12">
                            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                            <CheckBox
                                fx:id="chkMerchandising"
                                onAction="#actualizarTotal"
                                style="-fx-text-fill: #CCC; -fx-font-size: 13px;"/>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Merchandising"
                                       style="-fx-text-fill: #CCC; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label text="Camiseta oficial + poster del evento"
                                       style="-fx-text-fill: #555; -fx-font-size: 11px;"/>
                            </VBox>
                            <Label text="+ $20.000"
                                   style="-fx-text-fill: #E8C547; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Parqueadero -->
                        <HBox
                            style="-fx-background-color: #161616;
                                   -fx-border-color: #222; -fx-border-width: 1;
                                   -fx-border-radius: 6; -fx-background-radius: 6;"
                            alignment="CENTER_LEFT"
                            spacing="12">
                            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                            <CheckBox
                                fx:id="chkParqueadero"
                                onAction="#actualizarTotal"
                                style="-fx-text-fill: #CCC; -fx-font-size: 13px;"/>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Parqueadero"
                                       style="-fx-text-fill: #CCC; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label text="Reserva tu lugar en el parqueadero del recinto"
                                       style="-fx-text-fill: #555; -fx-font-size: 11px;"/>
                            </VBox>
                            <Label text="+ $15.000"
                                   style="-fx-text-fill: #E8C547; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Acceso preferencial -->
                        <HBox
                            style="-fx-background-color: #161616;
                                   -fx-border-color: #222; -fx-border-width: 1;
                                   -fx-border-radius: 6; -fx-background-radius: 6;"
                            alignment="CENTER_LEFT"
                            spacing="12">
                            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                            <CheckBox
                                fx:id="chkPreferencial"
                                onAction="#actualizarTotal"
                                style="-fx-text-fill: #CCC; -fx-font-size: 13px;"/>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Acceso preferencial"
                                       style="-fx-text-fill: #CCC; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                                <Label text="Ingresa antes que el público general"
                                       style="-fx-text-fill: #555; -fx-font-size: 11px;"/>
                            </VBox>
                            <Label text="+ $25.000"
                                   style="-fx-text-fill: #E8C547; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        </HBox>

                    </VBox>

                    <Separator style="-fx-background-color: #1A1A1A;"/>

                    <!-- PASO 3: Método de pago -->
                    <VBox spacing="14">
                        <Label
                            text="3. Método de pago"
                            style="-fx-font-family: 'Georgia';
                                   -fx-font-size: 18px;
                                   -fx-font-weight: bold;
                                   -fx-text-fill: #EEEEEE;"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Selecciona:"
                                   style="-fx-text-fill: #555; -fx-font-size: 12px;"/>
                            <ComboBox
                                fx:id="cbMetodoPago"
                                prefWidth="220"
                                style="-fx-background-color: #1A1A1A;
                                       -fx-border-color: #2A2A2A;
                                       -fx-border-radius: 6; -fx-background-radius: 6;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- ── Columna derecha: resumen ──────────────── -->
            <VBox
                prefWidth="320"
                minWidth="280"
                style="-fx-background-color: #111111;
                       -fx-border-color: #1E1E1E;
                       -fx-border-width: 0 0 0 1;"
                spacing="0">

                <padding><Insets top="28" right="24" bottom="28" left="24"/></padding>

                <Label
                    text="Resumen"
                    style="-fx-font-family: 'Georgia';
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;
                           -fx-text-fill: #EEEEEE;"/>

                <Region prefHeight="16"/>

                <Separator style="-fx-background-color: #222;"/>

                <Region prefHeight="16"/>

                <!-- Evento -->
                <Label
                    fx:id="lblResumenEvento"
                    text=""
                    wrapText="true"
                    style="-fx-text-fill: #AAAAAA; -fx-font-size: 13px;"/>

                <Label
                    fx:id="lblResumenFecha"
                    text=""
                    style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-padding: 4 0 0 0;"/>

                <Region prefHeight="20"/>
                <Separator style="-fx-background-color: #1E1E1E;"/>
                <Region prefHeight="16"/>

                <!-- Desglose -->
                <Label
                    text="DESGLOSE"
                    style="-fx-text-fill: #444; -fx-font-size: 10px; -fx-font-weight: bold;"/>

                <Region prefHeight="8"/>

                <!-- Las líneas de desglose se generan dinámicamente -->
                <VBox
                    fx:id="panelDesglose"
                    spacing="6"/>

                <Region prefHeight="16"/>
                <Separator style="-fx-background-color: #222;"/>
                <Region prefHeight="16"/>

                <!-- Total -->
                <HBox alignment="CENTER_LEFT">
                    <Label
                        text="TOTAL"
                        style="-fx-text-fill: #666; -fx-font-size: 12px; -fx-font-weight: bold;"
                        HBox.hgrow="ALWAYS"/>
                    <Label
                        fx:id="lblTotal"
                        text="0"
                        style="-fx-font-family: 'Georgia';
                               -fx-font-size: 26px;
                               -fx-font-weight: bold;
                               -fx-text-fill: #E8C547;"/>
                </HBox>

                <Region prefHeight="20"/>

                <!-- Error -->
                <Label
                    fx:id="lblError"
                    text=""
                    visible="false"
                    managed="false"
                    wrapText="true"
                    style="-fx-text-fill: #E05555; -fx-font-size: 12px;"/>

                <Region prefHeight="8"/>

                <!-- Botón confirmar -->
                <Button
                    text="Confirmar Compra"
                    maxWidth="Infinity"
                    onAction="#confirmarCompra"
                    style="-fx-background-color: #E8C547;
                           -fx-text-fill: #0D0D0D;
                           -fx-font-weight: bold;
                           -fx-font-size: 14px;
                           -fx-padding: 14 0;
                           -fx-cursor: hand;
                           -fx-background-radius: 6;
                           -fx-font-family: 'Georgia';"/>

                <Region prefHeight="10"/>

                <Button
                    text="Cancelar"
                    maxWidth="Infinity"
                    onAction="#volver"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #555;
                           -fx-border-color: #2A2A2A; -fx-border-width: 1;
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-padding: 10 0;
                           -fx-cursor: hand;"/>

            </VBox>

        </HBox>
    </center>

</BorderPane>